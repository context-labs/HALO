# Copy this file to `.env` and fill in your key. Loaded by run_one_task.py
# via python-dotenv (same pattern as demo/openai-agents-sdk-demo/).

# Required: an OpenAI API key (or any OpenAI-compatible key — set
# OPENAI_BASE_URL too if pointing at LiteLLM / Azure / vLLM).
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: point at any OpenAI-compatible endpoint (LiteLLM proxy, Azure,
# vLLM). Leave unset for the OpenAI default.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: where to write the JSONL trace file. Defaults to
# ./traces/<task_id>.jsonl (set by --traces-dir on the CLI).
# HALO_TRACES_PATH=./traces.jsonl

# HuggingFace API token (for uploading curated traces). Get one at
# https://huggingface.co/settings/tokens — needs write access to inference-net org.
HF_TOKEN=hf_REPLACE_ME
