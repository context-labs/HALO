# Required for the Claude Code CLI (which the SDK spawns) to authenticate.
# Alternatively run `claude login` interactively; either path works.
ANTHROPIC_API_KEY=

# Optional — only needed when sending traces to the HALO hosted ingest service.
# Replace the TODO placeholders with the real endpoint + API key once HALO
# Cloud publishes them. See docs/integrations/claude-agent-sdk.md.
# OTEL_EXPORTER_OTLP_ENDPOINT=<TODO-halo-ingest-endpoint>
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <TODO-halo-api-key>

# Optional — set any of these to 0 if you do NOT want that content in your traces.
# Demo defaults are all 1 (full capture). See tracing.py for what each flag captures.
# OTEL_LOG_USER_PROMPTS=0
# OTEL_LOG_TOOL_DETAILS=0
# OTEL_LOG_TOOL_CONTENT=0
# OTEL_LOG_RAW_API_BODIES=0
