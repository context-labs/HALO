# Required for the default `task run:smoke` and any OpenAI model.
OPENAI_API_KEY=

# Optional: other providers wired through litellm. Add only what you need.
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=

# Optional: where AppWorld writes traces. Defaults to
# experiments/outputs/<experiment_name>/traces.jsonl under APPWORLD_ROOT.
# HALO_TRACES_PATH=
