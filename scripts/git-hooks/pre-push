#!/usr/bin/env bash
set -euo pipefail

REMOTE="${1:-}"
URL="${2:-}"
ZERO_OID="0000000000000000000000000000000000000000"
BASE_REF="origin/main"

REPO_ROOT="$(git rev-parse --show-toplevel)"
REFS_FILE="$(mktemp)"

cleanup() {
  rm -f "$REFS_FILE"
}

trap cleanup EXIT
cat > "$REFS_FILE"

# Skip pre-push checks when no Python sources changed (e.g. docs-only PRs).
has_python_changes() {
  while read -r local_ref local_oid remote_ref remote_oid; do
    if [[ -z "${local_ref:-}" || "$local_oid" == "$ZERO_OID" ]]; then
      continue
    fi

    local range
    if [[ "$remote_oid" == "$ZERO_OID" ]]; then
      range="$(git merge-base HEAD "$BASE_REF")..${local_oid}"
    else
      range="${remote_oid}..${local_oid}"
    fi

    if git diff --name-only "$range" | grep -qE '\.(py|pyi|toml)$|^Taskfile\.yml$|^pyrightconfig\.json$|^uv\.lock$'; then
      return 0
    fi
  done < "$REFS_FILE"

  return 1
}

if ! has_python_changes; then
  exit 0
fi

echo "pre-push: Python changes detected, running checks..."

cd "$REPO_ROOT"
task check:pre-push || {
  echo "pre-push: checks failed. Push aborted."
  exit 1
}

echo "pre-push: checks passed."
